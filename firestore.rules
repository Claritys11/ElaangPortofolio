
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    match /users/{ownerId}/secureMessages/{messageId} {
      allow create: if true;
      allow read, list, update, delete: if true; 
    }

    match /securePageAccessLogs/{logId} {
      allow create: if true;
      allow read, list: if true;
    }

    match /ctfWriteups/{writeupId} {
      allow read, list: if true;
      allow create, update, delete: if true;
    }
  }
}
