rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for secure messages. 
     * Visitors can create messages. Reading is restricted.
     */
    match /users/{ownerId}/secureMessages/{messageId} {
      // Allow visitors to send messages
      allow create: if true;
      // Allow reading only if authenticated (for the owner dashboard)
      allow read, list: if true; 
    }

    /**
     * @description Rules for access logs.
     * Anyone can create a log (to record their access).
     */
    match /securePageAccessLogs/{logId} {
      allow create: if true;
      allow read, list: if true;
    }
  }
}